<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DaySave.app</title>
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">DaySave.app</a>
      <div class="d-flex ms-auto">
        <% if (user) { %>
          <a href="/dashboard" class="btn btn-outline-primary me-2">Dashboard</a>
          <a href="/auth/logout" class="btn btn-outline-danger">Logout</a>
        <% } else { %>
          <a href="/auth/login" class="btn btn-outline-primary">Login</a>
        <% } %>
      </div>
    </div>
  </nav>
  <div class="container mt-5">
    <div class="jumbotron text-center">
      <h1 class="display-4">Welcome to DaySave.app</h1>
      <p class="lead">Organize, analyze, and share content from 11 social platforms.</p>
    </div>
  </div>
  <!-- Bootstrap 5 JS Bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html> 