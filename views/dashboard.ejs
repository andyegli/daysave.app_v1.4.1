<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">
                <img src="/images/daysave-logo.png" alt="DaySave" width="30" height="30" class="d-inline-block align-text-top me-2">
                DaySave
            </a>
            <div class="navbar-nav ms-auto">
                <% if (user) { %>
                    <a href="/dashboard" class="btn btn-outline-light me-2">Dashboard</a>
                    <a href="/auth/logout" class="btn btn-outline-danger">Logout</a>
                <% } else { %>
                    <a href="/auth/login" class="btn btn-outline-light">Login</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <h1 class="mb-4">Welcome, <%= user.first_name ? user.first_name : user.username %>!</h1>
                
                <div class="row">
                    <div class="col-md-4 mb-4">
                        <div class="card">
                            <div class="card-body text-center">
                                <i class="fas fa-share-alt fa-3x text-primary mb-3"></i>
                                <h5 class="card-title">Social Integrations</h5>
                                <p class="card-text">Connect your social media accounts</p>
                                <a href="#" class="btn btn-primary">Connect Accounts</a>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-4 mb-4">
                        <div class="card">
                            <div class="card-body text-center">
                                <i class="fas fa-file-upload fa-3x text-success mb-3"></i>
                                <h5 class="card-title">File Management</h5>
                                <p class="card-text">Upload and organize your files</p>
                                <a href="#" class="btn btn-success">Upload Files</a>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-4 mb-4">
                        <div class="card">
                            <div class="card-body text-center">
                                <i class="fas fa-address-book fa-3x text-info mb-3"></i>
                                <h5 class="card-title">Contacts</h5>
                                <p class="card-text">Manage your contacts and groups</p>
                                <a href="#" class="btn btn-info">Manage Contacts</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h5 class="mb-0">Account Information</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <p><strong>Username:</strong> <%= user.username %></p>
                                        <p><strong>Email:</strong> <%= user.email %></p>
                                    </div>
                                    <div class="col-md-6">
                                        <p><strong>Subscription:</strong> 
                                            <span class="badge bg-<%= user.subscription_status === 'trial' ? 'warning' : 'success' %>">
                                                <%= user.subscription_status %>
                                            </span>
                                        </p>
                                        <p><strong>Language:</strong> <%= user.language %></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html> 