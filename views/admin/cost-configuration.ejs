<%- include('../partials/header') %>

<div class="container-fluid">
  <div class="row">
    <!-- Page Header -->
    <div class="col-12 mb-4">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h3 mb-0">Cost Configuration</h1>
          <p class="text-muted mb-0">Manage AI and storage pricing for accurate cost tracking</p>
        </div>
        <div>
          <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPricingModal">
            <i class="fas fa-plus me-1"></i> Add New Pricing
          </button>
        </div>
      </div>
    </div>

    <!-- AI Pricing Configuration -->
    <div class="col-12 mb-4">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-0 pt-4 pb-0">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h5 class="card-title mb-0">AI Provider Pricing</h5>
              <p class="text-muted small mb-0">Configure costs per million tokens for AI models</p>
            </div>
            <button type="button" class="btn btn-outline-success btn-sm" onclick="exportPricing('ai')">
              <i class="fas fa-download me-1"></i> Export
            </button>
          </div>
        </div>
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Provider</th>
                  <th>Model</th>
                  <th>Input Cost<br><small class="text-muted">per 1M tokens</small></th>
                  <th>Output Cost<br><small class="text-muted">per 1M tokens</small></th>
                  <th>Thinking Cost<br><small class="text-muted">per 1M tokens</small></th>
                  <th>Special Pricing</th>
                  <th>Status</th>
                  <th>Effective Date</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% aiPricing.forEach(pricing => { %>
                <tr>
                  <td>
                    <span class="badge bg-<%= pricing.provider === 'openai' ? 'primary' : (pricing.provider === 'google_ai' ? 'success' : 'info') %>">
                      <%= pricing.provider.toUpperCase() %>
                    </span>
                  </td>
                  <td>
                    <strong><%= pricing.model %></strong>
                  </td>
                  <td>
                    <span class="text-success">$<%= parseFloat(pricing.input_cost_per_million_tokens).toFixed(2) %></span>
                  </td>
                  <td>
                    <span class="text-warning">$<%= parseFloat(pricing.output_cost_per_million_tokens).toFixed(2) %></span>
                  </td>
                  <td>
                    <% if (pricing.thinking_cost_per_million_tokens) { %>
                      <span class="text-info">$<%= parseFloat(pricing.thinking_cost_per_million_tokens).toFixed(2) %></span>
                    <% } else { %>
                      <span class="text-muted">-</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (pricing.special_pricing_unit && pricing.special_pricing_cost) { %>
                      <small>
                        $<%= parseFloat(pricing.special_pricing_cost).toFixed(4) %><br>
                        <span class="text-muted"><%= pricing.special_pricing_unit.replace('_', ' ') %></span>
                      </small>
                    <% } else { %>
                      <span class="text-muted">-</span>
                    <% } %>
                  </td>
                  <td>
                    <span class="badge bg-<%= pricing.is_active ? 'success' : 'secondary' %>">
                      <%= pricing.is_active ? 'Active' : 'Inactive' %>
                    </span>
                  </td>
                  <td>
                    <small><%= new Date(pricing.effective_date).toLocaleDateString() %></small>
                  </td>
                  <td>
                    <div class="btn-group btn-group-sm" role="group">
                      <button type="button" class="btn btn-outline-primary" onclick="editPricing('<%= pricing.id %>', 'ai')">
                        <i class="fas fa-edit"></i>
                      </button>
                      <button type="button" class="btn btn-outline-danger" onclick="deletePricing('<%= pricing.id %>', 'ai')">
                        <i class="fas fa-trash"></i>
                      </button>
                    </div>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Storage Pricing Configuration -->
    <div class="col-12 mb-4">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-0 pt-4 pb-0">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h5 class="card-title mb-0">Storage Provider Pricing</h5>
              <p class="text-muted small mb-0">Configure storage, operation, and egress costs</p>
            </div>
            <button type="button" class="btn btn-outline-success btn-sm" onclick="exportPricing('storage')">
              <i class="fas fa-download me-1"></i> Export
            </button>
          </div>
        </div>
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Provider</th>
                  <th>Storage Class</th>
                  <th>Storage Cost<br><small class="text-muted">per GB/month</small></th>
                  <th>Operation Cost<br><small class="text-muted">per 1K ops</small></th>
                  <th>Egress Cost<br><small class="text-muted">per GB</small></th>
                  <th>Status</th>
                  <th>Effective Date</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% storagePricing.forEach(pricing => { %>
                <tr>
                  <td>
                    <span class="badge bg-<%= pricing.provider === 'google_cloud_storage' ? 'primary' : (pricing.provider === 'local' ? 'secondary' : 'info') %>">
                      <%= pricing.provider.toUpperCase().replace('_', ' ') %>
                    </span>
                  </td>
                  <td>
                    <strong><%= pricing.storage_class.replace('_', ' ').toUpperCase() %></strong>
                  </td>
                  <td>
                    <span class="text-success">$<%= parseFloat(pricing.storage_cost_per_gb_month).toFixed(4) %></span>
                  </td>
                  <td>
                    <span class="text-warning">$<%= parseFloat(pricing.operation_cost_per_1k).toFixed(4) %></span>
                  </td>
                  <td>
                    <span class="text-info">$<%= parseFloat(pricing.egress_cost_per_gb).toFixed(4) %></span>
                  </td>
                  <td>
                    <span class="badge bg-<%= pricing.is_active ? 'success' : 'secondary' %>">
                      <%= pricing.is_active ? 'Active' : 'Inactive' %>
                    </span>
                  </td>
                  <td>
                    <small><%= new Date(pricing.effective_date).toLocaleDateString() %></small>
                  </td>
                  <td>
                    <div class="btn-group btn-group-sm" role="group">
                      <button type="button" class="btn btn-outline-primary" onclick="editPricing('<%= pricing.id %>', 'storage')">
                        <i class="fas fa-edit"></i>
                      </button>
                      <button type="button" class="btn btn-outline-danger" onclick="deletePricing('<%= pricing.id %>', 'storage')">
                        <i class="fas fa-trash"></i>
                      </button>
                    </div>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Pricing Impact Analysis -->
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-0 pt-4 pb-0">
          <h5 class="card-title mb-0">Pricing Impact Analysis</h5>
          <p class="text-muted small mb-0">Analyze the impact of pricing changes on system costs</p>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-3">
              <div class="border rounded p-3 text-center">
                <h6 class="text-muted mb-1">Current Month Cost</h6>
                <h4 class="mb-0 text-success">$<%= currentMonthCost.toFixed(2) %></h4>
                <small class="text-muted">Total system cost</small>
              </div>
            </div>
            <div class="col-md-3">
              <div class="border rounded p-3 text-center">
                <h6 class="text-muted mb-1">AI Cost</h6>
                <h4 class="mb-0 text-primary">$<%= aiCost.toFixed(2) %></h4>
                <small class="text-muted"><%= Math.round((aiCost / currentMonthCost) * 100) || 0 %>% of total</small>
              </div>
            </div>
            <div class="col-md-3">
              <div class="border rounded p-3 text-center">
                <h6 class="text-muted mb-1">Storage Cost</h6>
                <h4 class="mb-0 text-warning">$<%= storageCost.toFixed(2) %></h4>
                <small class="text-muted"><%= Math.round((storageCost / currentMonthCost) * 100) || 0 %>% of total</small>
              </div>
            </div>
            <div class="col-md-3">
              <div class="border rounded p-3 text-center">
                <h6 class="text-muted mb-1">Active Models</h6>
                <h4 class="mb-0 text-info"><%= aiPricing.filter(p => p.is_active).length %></h4>
                <small class="text-muted">Configured models</small>
              </div>
            </div>
          </div>
          
          <div class="mt-4">
            <button type="button" class="btn btn-info" onclick="calculatePricingImpact()">
              <i class="fas fa-calculator me-1"></i> Calculate Impact
            </button>
            <button type="button" class="btn btn-outline-secondary ms-2" onclick="refreshData()">
              <i class="fas fa-sync-alt me-1"></i> Refresh Data
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Add/Edit Pricing Modal -->
<div class="modal fade" id="addPricingModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add New Pricing Configuration</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="pricingForm">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Pricing Type</label>
              <select class="form-select" name="type" required>
                <option value="">Select Type</option>
                <option value="ai">AI Model Pricing</option>
                <option value="storage">Storage Pricing</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Provider</label>
              <select class="form-select" name="provider" required>
                <option value="">Select Provider</option>
                <!-- AI Providers -->
                <option value="openai">OpenAI</option>
                <option value="google_ai">Google AI</option>
                <option value="google_cloud">Google Cloud</option>
                <option value="anthropic">Anthropic</option>
                <!-- Storage Providers -->
                <option value="google_cloud_storage">Google Cloud Storage</option>
                <option value="aws_s3">AWS S3</option>
                <option value="local">Local Storage</option>
              </select>
            </div>
            
            <!-- AI-specific fields -->
            <div id="aiFields" style="display: none;">
              <div class="col-12">
                <label class="form-label">Model Name</label>
                <input type="text" class="form-control" name="model" placeholder="e.g., gpt-4o-mini">
              </div>
              <div class="col-md-4">
                <label class="form-label">Input Cost ($per 1M tokens)</label>
                <input type="number" class="form-control" name="input_cost" step="0.000001" min="0">
              </div>
              <div class="col-md-4">
                <label class="form-label">Output Cost ($per 1M tokens)</label>
                <input type="number" class="form-control" name="output_cost" step="0.000001" min="0">
              </div>
              <div class="col-md-4">
                <label class="form-label">Thinking Cost ($per 1M tokens)</label>
                <input type="number" class="form-control" name="thinking_cost" step="0.000001" min="0">
              </div>
            </div>
            
            <!-- Storage-specific fields -->
            <div id="storageFields" style="display: none;">
              <div class="col-12">
                <label class="form-label">Storage Class</label>
                <select class="form-select" name="storage_class">
                  <option value="standard">Standard</option>
                  <option value="nearline">Nearline</option>
                  <option value="coldline">Coldline</option>
                  <option value="archive">Archive</option>
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label">Storage Cost ($per GB/month)</label>
                <input type="number" class="form-control" name="storage_cost" step="0.000001" min="0">
              </div>
              <div class="col-md-4">
                <label class="form-label">Operation Cost ($per 1K ops)</label>
                <input type="number" class="form-control" name="operation_cost" step="0.000001" min="0">
              </div>
              <div class="col-md-4">
                <label class="form-label">Egress Cost ($per GB)</label>
                <input type="number" class="form-control" name="egress_cost" step="0.000001" min="0">
              </div>
            </div>
            
            <div class="col-md-6">
              <label class="form-label">Effective Date</label>
              <input type="date" class="form-control" name="effective_date" required>
            </div>
            <div class="col-md-6">
              <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="is_active" checked>
                <label class="form-check-label">Active</label>
              </div>
            </div>
            <div class="col-12">
              <label class="form-label">Notes</label>
              <textarea class="form-control" name="notes" rows="2" placeholder="Additional notes about this pricing..."></textarea>
            </div>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="savePricing()">Save Pricing</button>
      </div>
    </div>
  </div>
</div>

<script>
// Show/hide fields based on pricing type
document.querySelector('select[name="type"]').addEventListener('change', function() {
  const aiFields = document.getElementById('aiFields');
  const storageFields = document.getElementById('storageFields');
  
  if (this.value === 'ai') {
    aiFields.style.display = 'block';
    storageFields.style.display = 'none';
  } else if (this.value === 'storage') {
    aiFields.style.display = 'none';
    storageFields.style.display = 'block';
  } else {
    aiFields.style.display = 'none';
    storageFields.style.display = 'none';
  }
});

// Set default effective date to today
document.querySelector('input[name="effective_date"]').value = new Date().toISOString().split('T')[0];

function savePricing() {
  const form = document.getElementById('pricingForm');
  const formData = new FormData(form);
  
  fetch('/admin/api/cost-configuration', {
    method: 'POST',
    body: formData
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      location.reload();
    } else {
      alert('Error saving pricing: ' + data.error);
    }
  })
  .catch(error => {
    console.error('Error:', error);
    alert('Error saving pricing');
  });
}

function editPricing(id, type) {
  // Implementation for editing pricing
  console.log('Edit pricing:', id, type);
}

function deletePricing(id, type) {
  if (confirm('Are you sure you want to delete this pricing configuration?')) {
    fetch(`/admin/api/cost-configuration/${id}`, {
      method: 'DELETE'
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        location.reload();
      } else {
        alert('Error deleting pricing: ' + data.error);
      }
    });
  }
}

function exportPricing(type) {
  window.open(`/admin/api/cost-configuration/export?type=${type}`, '_blank');
}

function calculatePricingImpact() {
  fetch('/admin/api/cost-configuration/impact')
    .then(response => response.json())
    .then(data => {
      alert(`Pricing Impact Analysis:\nCurrent Monthly Cost: $${data.currentCost}\nProjected Cost: $${data.projectedCost}\nDifference: $${data.difference}`);
    });
}

function refreshData() {
  location.reload();
}
</script>

<%- include('../partials/footer') %>
