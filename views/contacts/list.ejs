<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Contacts - DaySave</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .contact-list {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
      padding: 1.5rem;
      margin-top: 2rem;
    }
    .contact-actions {
      min-width: 120px;
    }
    .contact-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: #e9ecef;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      color: #495057;
      margin-right: 1rem;
    }
  </style>
</head>
<body>
  <%- include('../partials/header', { user }) %>
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mt-4">
      <h2 class="fw-bold">My Contacts</h2>
      <a href="/contacts/new" class="btn btn-success"><i class="fa fa-plus"></i> Add Contact</a>
    </div>
    <% if (error) { %>
      <div class="alert alert-danger mt-3"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success mt-3"><%= success %></div>
    <% } %>
    <div class="contact-list mt-3">
      <% if (contacts.length === 0) { %>
        <div class="text-center text-muted">No contacts found.</div>
      <% } else { %>
        <table class="table table-hover align-middle">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Phone</th>
              <th class="contact-actions">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% contacts.forEach(function(contact) { %>
              <tr>
                <td>
                  <div class="d-flex align-items-center">
                    <div class="contact-avatar">
                      <%= (contact.first_name[0] || '') + (contact.last_name[0] || '') %>
                    </div>
                    <%= contact.first_name %> <%= contact.last_name %>
                  </div>
                </td>
                <td><%= contact.email || '-' %></td>
                <td><%= contact.phone || '-' %></td>
                <td>
                  <a href="/contacts/<%= contact.id %>/edit" class="btn btn-sm btn-outline-primary me-2"><i class="fa fa-edit"></i> Edit</a>
                  <form method="POST" action="/contacts/<%= contact.id %>/delete" class="d-inline" onsubmit="return confirm('Delete this contact?');">
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa fa-trash"></i> Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html> 