<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Contacts - DaySave</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .contact-list {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
      padding: 1.5rem;
      margin-top: 2rem;
    }
    .contact-actions {
      min-width: 120px;
    }
    .contact-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: #e9ecef;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      color: #495057;
      margin-right: 1rem;
    }
  </style>
</head>
<body>
  <%- include('../partials/header', { user, title: 'My Contacts' }) %>
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mt-4">
      <h2 class="fw-bold">My Contacts</h2>
      <a href="/contacts/new" class="btn btn-success"><i class="fa fa-plus"></i> Add Contact</a>
    </div>
    <% if (error) { %>
      <div class="alert alert-danger mt-3"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success mt-3"><%= success %></div>
    <% } %>
    <div class="contact-list mt-3">
      <% if (contacts.length === 0) { %>
        <div class="text-center text-muted">No contacts found.</div>
      <% } else { %>
        <table class="table table-hover align-middle">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Addresses</th>
              <th class="contact-actions">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% contacts.forEach(function(contact) { %>
              <tr>
                <td>
                  <div class="d-flex align-items-center">
                    <div class="contact-avatar">
                      <% if (contact.name) { %>
                        <%= contact.name.split(' ').map(n => n[0]).join('').toUpperCase() %>
                      <% } else { %>
                        ?
                      <% } %>
                    </div>
                    <%= contact.name || '-' %>
                  </div>
                </td>
                <td>
                  <% if (contact.emails && contact.emails.length) { %>
                    <%= contact.emails.map(e => e.label + ': ' + e.value).join(', ') %>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td>
                  <% if (contact.phones && contact.phones.length) { %>
                    <%= contact.phones.map(p => p.label + ': ' + p.value).join(', ') %>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td>
                  <% if (contact.addresses && contact.addresses.length) { %>
                    <% contact.addresses.forEach(function(address, aidx) { %>
                      <span>
                        <%= address.label %>: <%= address.value %>
                        <a href="#" class="text-primary ms-1 show-map" data-address="<%= address.value.replace(/'/g, '&#39;') %>" title="Show on map">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-geo-alt-fill" viewBox="0 0 16 16">
                            <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/>
                          </svg>
                        </a>
                      </span><% if (aidx < contact.addresses.length - 1) { %>, <% } %>
                    <% }) %>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td>
                  <a href="/contacts/<%= contact.id %>/edit" class="btn btn-sm btn-outline-primary me-2"><i class="fa fa-edit"></i> Edit</a>
                  <form method="POST" action="/contacts/<%= contact.id %>/delete" class="d-inline" onsubmit="return confirm('Delete this contact?');">
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa fa-trash"></i> Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
  <!-- Google Map Modal -->
  <div class="modal fade" id="mapModal" tabindex="-1" aria-labelledby="mapModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="mapModalLabel">Address Location</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body" style="height:400px;">
          <div id="map" style="width:100%;height:100%;"></div>
        </div>
      </div>
    </div>
  </div>
  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://maps.googleapis.com/maps/api/js?key=<%= process.env.GOOGLE_MAPS_KEY %>" async defer></script>
  <script src="/js/contact-maps.js"></script>
</body>
</html> 